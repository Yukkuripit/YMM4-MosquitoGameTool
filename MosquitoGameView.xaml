<UserControl x:Class="MosquitoGame.MosquitoGameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="550" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 上部：情報表示 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <TextBlock Text="{Binding ScoreText}" FontSize="20" FontWeight="Bold" Margin="20,0"/>
            <TextBlock Text="{Binding TimeText}" FontSize="20" FontWeight="Bold" Margin="20,0"/>
            <TextBlock Text="{Binding HighScoreText}" FontSize="16" Margin="20,0"/>
        </StackPanel>

        <!-- ゲームエリア (蚊をクリックできるCanvas) -->
        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="2" Margin="20" Background="LightYellow">
			<Canvas x:Name="GameCanvas"
        Background="Transparent"
        MouseLeftButtonDown="GameCanvas_MouseLeftButtonDown"
        Loaded="GameCanvas_Loaded">
                <!-- 蚊の絵（簡易的な図形＋テキスト） -->
                <Button x:Name="MosquitoButton"
                        Command="{Binding HitMosquitoCommand}"
                        Width="40" Height="40"
                        Canvas.Left="{Binding MosquitoX}"
                        Canvas.Top="{Binding MosquitoY}"
                        Background="Black"
                        Foreground="White"
                        FontSize="24"
                        FontFamily="Segoe UI Emoji"
                        Cursor="Hand">
                    🦟
                </Button>
            </Canvas>
        </Border>

        <!-- 下部：操作ボタンとメッセージ -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Command="{Binding StartGameCommand}" Content="ゲーム開始" Width="100" Height="40" Margin="10" Background="Green" Foreground="White"/>
            <TextBlock Text="{Binding GameStatusText}" FontSize="16" VerticalAlignment="Center" Margin="20,0"/>
        </StackPanel>
    </Grid>
</UserControl>